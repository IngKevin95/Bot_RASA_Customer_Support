# Variables de entorno para el contenedor Chatwoot
# Copiar a .env.chatwoot y completar antes de ejecutar docker compose up

# Clave secreta de Rails (generar con: openssl rand -hex 64)
SECRET_KEY_BASE=cambiar_por_clave_segura_generada_con_openssl_rand_hex_64

# URL publica de la instancia (puede ser http://localhost:3000 en local)
FRONTEND_URL=http://localhost:3000

# Correo del administrador inicial
DEFAULT_LOCALE=es
RAILS_LOG_TO_STDOUT=true

# SMTP para notificaciones (opcional en local)
# SMTP_ADDRESS=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER_NAME=tu@gmail.com
# SMTP_PASSWORD=tu_app_password
# SMTP_AUTHENTICATION=login
# SMTP_ENABLE_STARTTLS_AUTO=true
# MAILER_SENDER_EMAIL=no-reply@tudominio.com
