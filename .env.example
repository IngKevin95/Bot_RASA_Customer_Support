# Copia este archivo a .env antes de correr el proyecto:
# cp .env.example .env
#
# IMPORTANTE: nunca subas .env al repositorio.

# -----------------------------------------------
# Escalacion — selecciona el proveedor activo
# Valores posibles: stub | chatwoot | genesys
# -----------------------------------------------
ESCALATION_PROVIDER=stub
ESCALATION_QUEUE=soporte_general

# -----------------------------------------------
# RASA Server
# -----------------------------------------------
RASA_PORT=5005
RASA_CORS_ORIGINS=*

# -----------------------------------------------
# Action Server
# -----------------------------------------------
ACTION_SERVER_HOST=localhost
ACTION_SERVER_PORT=5055

# -----------------------------------------------
# Chatwoot — solo requerido si ESCALATION_PROVIDER=chatwoot
# Docs: docs/local-setup.md#chatwoot
# -----------------------------------------------
CHATWOOT_URL=http://localhost:3000
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_INBOX_ID=

# -----------------------------------------------
# Genesys Cloud — solo requerido si ESCALATION_PROVIDER=genesys
# Docs: https://developer.genesys.cloud/api/rest/v2/
# -----------------------------------------------
GENESYS_ORG_ID=mypurecloud.com
GENESYS_CLIENT_ID=
GENESYS_CLIENT_SECRET=
GENESYS_QUEUE_ID=

# -----------------------------------------------
# GCP - Deploy en Cloud Run (ver docs/gcp-setup.md)
# -----------------------------------------------
GCP_PROJECT_ID=mi-proyecto-gcp
GCP_REGION=us-central1
GCP_SERVICE_NAME=customer-support-bot
