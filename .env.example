# Copia este archivo a .env antes de correr el proyecto:
# cp .env.example .env
#
# IMPORTANTE: nunca subas .env al repositorio.

# -----------------------------------------------
# GCP - Deploy en Cloud Run
# -----------------------------------------------
GCP_PROJECT_ID=mi-proyecto-gcp
GCP_REGION=us-central1
GCP_SERVICE_NAME=customer-support-bot

# -----------------------------------------------
# RASA Server
# -----------------------------------------------
RASA_PORT=5005
RASA_CORS_ORIGINS=*

# -----------------------------------------------
# Action Server
# -----------------------------------------------
ACTION_SERVER_HOST=localhost
ACTION_SERVER_PORT=5055

# -----------------------------------------------
# Genesys Cloud - Escalado a agente humano
# -----------------------------------------------
GENESYS_QUEUE=soporte_general
GENESYS_ORG_ID=
GENESYS_CLIENT_ID=
GENESYS_CLIENT_SECRET=
